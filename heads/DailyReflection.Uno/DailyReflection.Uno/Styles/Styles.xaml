<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Migrated from MAUI Styles.xaml to WinUI ResourceDictionary -->
	<!-- WinUI uses different naming conventions for some properties -->

	<!-- Page/Content Background -->
	<StaticResource x:Key="PageBackgroundBrush" ResourceKey="Gray100Brush" />

	<!--
		Implicit Page style (spec 004 §B). Restores the original Xamarin
		palette (BackgroundColorLight/Dark) without each page having to set
		Background explicitly.
	-->
	<Style TargetType="Page">
		<Setter Property="Background" Value="{ThemeResource DRPageBackgroundBrush}" />
	</Style>

	<!--
		Implicit TextBlock style. Provides the original TextPrimaryColor
		under both themes, so plain TextBlocks get the right Foreground
		without each consumer specifying it.
	-->
	<Style TargetType="TextBlock">
		<Setter Property="Foreground" Value="{ThemeResource DRTextPrimaryBrush}" />
	</Style>

	<!--
		Implicit CommandBar style. Background / Foreground are populated by
		App.ApplyCommandBarChrome() at runtime so the values can branch on
		OS (Android = primary blue, iOS = page background + iOS blue, desktop
		= page background + primary text). DR* keys live in App resources.
	-->
	<Style TargetType="CommandBar">
		<Setter Property="Background" Value="{ThemeResource DRCommandBarBackgroundBrush}" />
		<Setter Property="Foreground" Value="{ThemeResource DRCommandBarForegroundBrush}" />
	</Style>

	<!-- Title Style -->
	<Style x:Key="TitleTextStyle"
		   TargetType="TextBlock">
		<Setter Property="FontSize" Value="24" />
		<Setter Property="FontWeight" Value="SemiBold" />
		<Setter Property="TextWrapping" Value="Wrap" />
	</Style>

	<!-- Subtitle Style -->
	<Style x:Key="SubtitleTextStyle"
		   TargetType="TextBlock">
		<Setter Property="FontSize" Value="20" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="TextWrapping" Value="Wrap" />
	</Style>

	<!-- Body Style -->
	<Style x:Key="BodyTextStyle"
		   TargetType="TextBlock">
		<Setter Property="FontSize" Value="14" />
		<Setter Property="TextWrapping" Value="Wrap" />
	</Style>

	<!-- Caption Style -->
	<Style x:Key="CaptionTextStyle"
		   TargetType="TextBlock">
		<Setter Property="FontSize" Value="12" />
		<Setter Property="TextWrapping" Value="Wrap" />
		<Setter Property="Opacity" Value="0.7" />
	</Style>

	<!-- Headline Style -->
	<Style x:Key="Headline"
		   TargetType="TextBlock">
		<Setter Property="FontSize" Value="32" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="TextAlignment" Value="Center" />
	</Style>

	<!-- SubHeadline Style -->
	<Style x:Key="SubHeadline"
		   TargetType="TextBlock">
		<Setter Property="FontSize" Value="24" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="TextAlignment" Value="Center" />
	</Style>

	<!-- Italic Text Style -->
	<Style x:Key="ItalicTextStyle"
		   TargetType="TextBlock">
		<Setter Property="FontStyle" Value="Italic" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="TextWrapping" Value="Wrap" />
	</Style>

	<!-- Settings Item Style -->
	<Style x:Key="SettingsItemStyle"
		   TargetType="Grid">
		<Setter Property="Padding" Value="16,12" />
		<Setter Property="Background" Value="Transparent" />
	</Style>

</ResourceDictionary>
