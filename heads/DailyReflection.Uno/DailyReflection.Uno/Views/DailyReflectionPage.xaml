<?xml version="1.0" encoding="utf-8" ?>
<!--
    DailyReflectionPage
    Migrated from MAUI DailyReflectionView.xaml to WinUI/Uno Platform Page
    
    Control Mappings (based on Uno Platform docs):
    - ContentPage -> Page
    - StackLayout -> StackPanel
    - Label -> TextBlock
    - ActivityIndicator -> ProgressRing
    - ToolbarItems -> CommandBar (in Page's resources/content)
    - ScrollView -> ScrollViewer
    - x:DataType removed (WinUI uses x:Bind for compiled bindings)
    - StringFormat removed from bindings (use converters or x:Bind functions)
-->
<views:PageBase x:Class="DailyReflection.Views.DailyReflectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="using:DailyReflection.Converters"
      xmlns:vm="using:DailyReflection.Presentation.ViewModels"
      xmlns:views="using:DailyReflection.Views"
      AutomationProperties.AutomationId="daily_reflection_view"
      >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Top CommandBar replacing MAUI ToolbarItems. Content slot acts as the page title (matching Shell.Title binding to MMMM d). -->
        <CommandBar Grid.Row="0"
                    DefaultLabelPosition="Right">
            <CommandBar.Content>
                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource SubtitleTextStyle}"
                           Text="{x:Bind FormatPageDate(ViewModel.Date), Mode=OneWay}" />
            </CommandBar.Content>
            <AppBarButton x:Name="CalendarButton"
                          Label="Select Date"
                          AutomationProperties.AutomationId="change_date">
                <AppBarButton.Icon>
                    <FontIcon FontFamily="{StaticResource FontAwesomeRegular}"
                              Glyph="&#xf073;" />
                </AppBarButton.Icon>
                <!-- AutomationProperties.AutomationId for the picker is applied to the
                     owning AppBarButton above (change_date); the FlyoutBase doesn't
                     accept attached automation properties in WinUI/Uno. -->
                <AppBarButton.Flyout>
                    <DatePickerFlyout x:Name="DatePickerFlyout"
                                      DatePicked="DatePickerFlyout_DatePicked" />
                </AppBarButton.Flyout>
            </AppBarButton>
            <CommandBar.SecondaryCommands>
                <AppBarButton Label="Share"
                              Command="{x:Bind ViewModel.ShareCommand}"
                              AutomationProperties.AutomationId="share_reflection">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="{StaticResource FontAwesomeRegular}"
                                  Glyph="&#xf14d;" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <ScrollViewer Grid.Row="1">
            <Grid>
                <!--
                    Main content - visible when not loading and no error.
                    The Title / Reading / Thought TextBlocks are populated via code-behind:
                    ParseInlines() splits the DB markup (<i>…</i>, <br/>) into Run / LineBreak
                    inlines so inline italics in the source data render correctly.
                -->
                <StackPanel Margin="20"
                            Visibility="{x:Bind ShowContent(ViewModel.HasError, ViewModel.GetDailyReflectionCommand.IsRunning), Mode=OneWay}">

                    <!--  Title  -->
                    <TextBlock x:Name="TitleText"
                               Style="{StaticResource TitleTextStyle}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               AutomationProperties.AutomationId="reflection_title" />

                    <!--  Reading/Quote — italic at the block level so any inline italics nest as upright (matching <i> inside <i>).  -->
                    <TextBlock x:Name="ReadingText"
                               Margin="0,20,0,0"
                               FontStyle="Italic"
                               Style="{StaticResource BodyTextStyle}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               AutomationProperties.AutomationId="reflection_quote" />

                    <!--  Source  -->
                    <TextBlock Style="{StaticResource BodyTextStyle}"
                               AutomationProperties.AutomationId="reflection_quoteSource">
                        <Run Text="— " />
                        <Run Text="{x:Bind ViewModel.DailyReflection.Source, Mode=OneWay}" />
                    </TextBlock>

                    <!--  Thought  -->
                    <TextBlock x:Name="ThoughtText"
                               Margin="0,20,0,0"
                               Style="{StaticResource BodyTextStyle}"
                               TextWrapping="Wrap"
                               AutomationProperties.AutomationId="reflection_thought" />

                    <!--  Copyright  -->
                    <TextBlock Style="{StaticResource CaptionTextStyle}"
                               Margin="0,20,0,0"
                               TextWrapping="Wrap"
                               AutomationProperties.AutomationId="reflection_copyright">
                        <Run Text="From the book " />
                        <Run FontStyle="Italic"
                             Text="Daily Reflections" />
                        <LineBreak />
                        <Run Text="Copyright © 1990 by Alcoholics Anonymous World Services, Inc." />
                    </TextBlock>
                </StackPanel>

                <!--  Error message  -->
                <Grid Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="An error occurred. Please try again." />
                </Grid>

                <!--
                    Loading indicator — declared LAST so its z-order is above the
                    StackPanel and error grid, matching the Xamarin original
                    where ActivityIndicator was the last child of the Grid.
                -->
                <ProgressRing HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              IsActive="{x:Bind ViewModel.GetDailyReflectionCommand.IsRunning, Mode=OneWay}" />
            </Grid>
        </ScrollViewer>
    </Grid>
</views:PageBase>
